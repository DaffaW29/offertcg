# Default live provider. Uses the Pokemon TCG API and falls back to mock data on errors.
PRICE_PROVIDER=pokemon-tcg

# Optional. Pokemon TCG API works without a key at lower rate limits.
# Sign up at https://dev.pokemontcg.io/ and keep this server-side only.
POKEMON_TCG_API_KEY=

# Future official TCGplayer integration only. Do not expose these in frontend code.
# TCGPLAYER_PUBLIC_KEY=
# TCGPLAYER_PRIVATE_KEY=
